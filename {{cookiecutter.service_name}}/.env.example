# {{ cookiecutter.service_name }} — copy to .env for local development

APP_PORT={{ cookiecutter.default_port }}
APP_ENVIRONMENT=development
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=text
APP_LOG_TO_CONSOLE=true
APP_LOG_DIR=logs

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ds_{{ cookiecutter.service_name }}_db
POSTGRES_MIN_POOL_SIZE=5
POSTGRES_MAX_POOL_SIZE=20

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PREFIX=ds_{{ cookiecutter.service_name }}:
REDIS_DEFAULT_TTL=3600

JWT_ALGORITHM=RS256
JWT_ISSUER={{ cookiecutter.service_name }}
JWT_AUDIENCE=drivestream
JWT_PUBLIC_KEY_PATH=tests/fixtures/jwt_public.pem

OTEL_SERVICE_NAME={{ cookiecutter.service_name }}
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
