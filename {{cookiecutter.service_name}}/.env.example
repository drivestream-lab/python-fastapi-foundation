# {{cookiecutter.service_name}} local environment — copy to .env and fill values

APP_PORT={{cookiecutter.default_port}}
APP_ENVIRONMENT=development
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=text
{% if cookiecutter.has_postgres == "yes" %}
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB={{cookiecutter.service_name}}_db
{% endif %}
{% if cookiecutter.has_redis == "yes" %}
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PREFIX=ds_{{cookiecutter.service_name}}:
{% endif %}
{% if cookiecutter.has_kafka == "yes" %}
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID={{cookiecutter.service_name}}-consumer
KAFKA_TOPICS=[]
{% endif %}
{% if cookiecutter.auth_mode == "jwt" %}
JWT_ISSUER=parichay
JWT_AUDIENCE={{cookiecutter.service_name}}
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=keys/public.pem
{% endif %}
{% if cookiecutter.has_telemetry == "yes" %}
OTEL_ENABLED=true
OTEL_ENDPOINT=http://localhost:4318
{% endif %}
